{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the hotel app, including guests and admins.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "legalName": { "type": "string" },
        "phone": { "type": "string" },
        "guardianName": { "type": "string" },
        "guardianPhone": { "type": "string" },
        "nidNumber": { "type": "string" },
        "nidImageUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "profileCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "profileCompleted", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "A hotel room available for booking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Single Delux", "Double Delux", "Family Suite", "Super Deluxe"] },
        "price": { "type": "number" },
        "cutPrice": { "type": "number" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "type", "price", "isAvailable", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking made by a user for a room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "userEmail": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "accepted", "rejected", "cancelled", "completed"] },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "roomId", "checkIn", "checkOut", "status", "totalAmount", "createdAt"]
    },
    "Content": {
      "title": "Content",
      "description": "Dynamic content for the website, editable by admins.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "section": { "type": "string" },
        "data": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "section", "data", "updatedAt"]
    },
    "Rating": {
      "title": "Rating",
      "description": "A review or rating left by a guest.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "status", "createdAt"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "An image or post in the gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "hidden", "archived"] },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["id", "imageUrl", "createdAt", "status"]
    },
    "SocialLink": {
      "title": "SocialLink",
      "description": "A social media link for the footer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platform": { "type": "string" },
        "url": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "platform", "url", "icon"]
    },
    "EmailLog": {
      "title": "EmailLog",
      "description": "A log of an email sent by the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "to", "subject", "sentAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "logoUrl": { "type": "string" },
        "websiteName": { "type": "string" },
        "galleryCleanupThreshold": { "type": "number" },
        "lastCleanupDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Stores hotel rooms."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Stores room bookings."
    },
    "/content/{contentId}": {
      "schema": { "$ref": "#/entities/Content" },
      "description": "Stores dynamic website content."
    },
    "/ratings/{ratingId}": {
      "schema": { "$ref": "#/entities/Rating" },
      "description": "Stores guest reviews and ratings."
    },
    "/gallery/{postId}": {
      "schema": { "$ref": "#/entities/Gallery" },
      "description": "Stores gallery posts."
    },
    "/socialLinks/{linkId}": {
      "schema": { "$ref": "#/entities/SocialLink" },
      "description": "Stores social media links."
    },
    "/emailLogs/{logId}": {
      "schema": { "$ref": "#/entities/EmailLog" },
      "description": "Stores logs of sent emails."
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores global settings."
    }
  }
}
